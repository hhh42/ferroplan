;; kiln-pack size 4: 4 two-stage jobs (durations alternate 3/5)
;; through 8-long kiln windows with 2 slots. Generated by gen_kiln_pack.py.
(define (problem kiln-pack-4)
  (:domain kiln-pack)
  (:objects j1 j2 j3 j4 - job s1 s2 - slot)
  (:init (cold) (free s1) (free s2) (raw j1) (= (bake-time j1) 3) (raw j2) (= (bake-time j2) 5) (raw j3) (= (bake-time j3) 3) (raw j4) (= (bake-time j4) 5))
  (:goal (and (baked j1) (baked j2) (baked j3) (baked j4)))
  (:metric minimize (total-time)))
