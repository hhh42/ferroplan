;; p4: 4 jobs x 3 stages x 3 machines (~36 operate groundings). contention: more jobs than machines
(define (problem p4) (:domain jobshop)
  (:objects j1 j2 j3 j4 - job  s1 s2 s3 - stage  m1 m2 m3 - machine)
  (:init
    (next s1 s2)
    (next s2 s3)
    (at-stage j1 s1) (final-stage j1 s3)
    (route j1 s1 m3) (= (proctime j1 s1) 4)
    (route j1 s2 m1) (= (proctime j1 s2) 2)
    (route j1 s3 m2) (= (proctime j1 s3) 3)
    (at-stage j2 s1) (final-stage j2 s3)
    (route j2 s1 m1) (= (proctime j2 s1) 2)
    (route j2 s2 m2) (= (proctime j2 s2) 3)
    (route j2 s3 m3) (= (proctime j2 s3) 4)
    (at-stage j3 s1) (final-stage j3 s3)
    (route j3 s1 m2) (= (proctime j3 s1) 3)
    (route j3 s2 m3) (= (proctime j3 s2) 4)
    (route j3 s3 m1) (= (proctime j3 s3) 2)
    (at-stage j4 s1) (final-stage j4 s3)
    (route j4 s1 m3) (= (proctime j4 s1) 4)
    (route j4 s2 m1) (= (proctime j4 s2) 2)
    (route j4 s3 m2) (= (proctime j4 s3) 3)
    (free m1)
    (free m2)
    (free m3)
  )
  (:goal (and (job-complete j1) (job-complete j2) (job-complete j3) (job-complete j4))))
