;; p5: 5 jobs x 5 stages x 5 machines (~125 operate groundings). 5x5
(define (problem p5) (:domain jobshop)
  (:objects j1 j2 j3 j4 j5 - job  s1 s2 s3 s4 s5 - stage  m1 m2 m3 m4 m5 - machine)
  (:init
    (next s1 s2)
    (next s2 s3)
    (next s3 s4)
    (next s4 s5)
    (at-stage j1 s1) (final-stage j1 s5)
    (route j1 s1 m3) (= (proctime j1 s1) 4)
    (route j1 s2 m4) (= (proctime j1 s2) 2)
    (route j1 s3 m5) (= (proctime j1 s3) 3)
    (route j1 s4 m1) (= (proctime j1 s4) 4)
    (route j1 s5 m2) (= (proctime j1 s5) 2)
    (at-stage j2 s1) (final-stage j2 s5)
    (route j2 s1 m4) (= (proctime j2 s1) 2)
    (route j2 s2 m5) (= (proctime j2 s2) 3)
    (route j2 s3 m1) (= (proctime j2 s3) 4)
    (route j2 s4 m2) (= (proctime j2 s4) 2)
    (route j2 s5 m3) (= (proctime j2 s5) 3)
    (at-stage j3 s1) (final-stage j3 s5)
    (route j3 s1 m5) (= (proctime j3 s1) 3)
    (route j3 s2 m1) (= (proctime j3 s2) 4)
    (route j3 s3 m2) (= (proctime j3 s3) 2)
    (route j3 s4 m3) (= (proctime j3 s4) 3)
    (route j3 s5 m4) (= (proctime j3 s5) 4)
    (at-stage j4 s1) (final-stage j4 s5)
    (route j4 s1 m1) (= (proctime j4 s1) 4)
    (route j4 s2 m2) (= (proctime j4 s2) 2)
    (route j4 s3 m3) (= (proctime j4 s3) 3)
    (route j4 s4 m4) (= (proctime j4 s4) 4)
    (route j4 s5 m5) (= (proctime j4 s5) 2)
    (at-stage j5 s1) (final-stage j5 s5)
    (route j5 s1 m2) (= (proctime j5 s1) 2)
    (route j5 s2 m3) (= (proctime j5 s2) 3)
    (route j5 s3 m4) (= (proctime j5 s3) 4)
    (route j5 s4 m5) (= (proctime j5 s4) 2)
    (route j5 s5 m1) (= (proctime j5 s5) 3)
    (free m1)
    (free m2)
    (free m3)
    (free m4)
    (free m5)
  )
  (:goal (and (job-complete j1) (job-complete j2) (job-complete j3) (job-complete j4) (job-complete j5))))
